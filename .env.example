# Kopiera till .env för lokal utveckling. Sätts som Railway-miljövariabler i produktion.

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-6   # default; överstyr om modellen byter namn

# Bezala
BEZALA_PASSWORD=
BEZALA_USERNAME=
BEZALA_API_URL=https://api.bezala.com

# OAuth-klient (samma för både Gmail och Drive — båda skapas i samma
# Google Cloud-projekt och godkänns av två olika användare).
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=

# Refresh-token för Gmail-kontot (Visma).
#   Kör:  python scripts/generate_token.py --target gmail
# Scopes: gmail.modify, gmail.readonly, gmail.labels
GMAIL_REFRESH_TOKEN=

# Refresh-token för Drive-kontot (privat Gmail där mappen ligger).
# Visma Workspace blockerar extern delning av Drive-mappar — därför
# använder vi ett separat konto för uppladdning.
#   Kör:  python scripts/generate_token.py --target drive
# Scopes: drive.file, drive.readonly
DRIVE_REFRESH_TOKEN=

# Drive-mappen där kvitton sparas (ligger i privat Drive).
GOOGLE_DRIVE_FOLDER_ID=1FoK-nmaDLgIUnMUImECjxXBO9XqLgFZb

# Databas (Railway sätter detta automatiskt när du lägger till PostgreSQL-plugin)
DATABASE_URL=postgresql://user:pass@localhost:5432/bezalabot

# Schemaläggare
SCAN_INTERVAL_MINUTES=60
SCAN_ENABLED=true

# App
LOG_LEVEL=INFO

# Auth — lösenord för att logga in i dashboarden
APP_PASSWORD=

# Session-cookie-signering. Generera med:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=
