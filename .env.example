# Kopiera till .env för lokal utveckling. Sätts som Railway-miljövariabler i produktion.

# Claude AI
ANTHROPIC_API_KEY=sk-ant-...

# Bezala
BEZALA_PASSWORD=
BEZALA_USERNAME=
BEZALA_API_URL=https://api.bezala.com

# Gmail OAuth (kör scripts/generate_token.py lokalt för att få refresh_token)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# Google Drive (service account — klistra in HELA JSON-filen som en sträng)
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=1RpXxsdO_PB2VRjJi3yVyNQLDPGkLt0O8

# Databas (Railway sätter detta automatiskt när du lägger till PostgreSQL-plugin)
DATABASE_URL=postgresql://user:pass@localhost:5432/bezalabot

# Schemaläggare
SCAN_INTERVAL_MINUTES=60
SCAN_ENABLED=true

# App
LOG_LEVEL=INFO
