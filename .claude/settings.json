{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": [
      "Bash(railway:*)",
      "Bash(git push:*)",
      "Bash(git fetch:*)",
      "Bash(gh pr:*)",
      "Bash(gh api:*)",
      "Bash(pytest:*)",
      "Bash(npm run:*)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
